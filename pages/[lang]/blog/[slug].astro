---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t, locales, type Locale } from '../../../i18n/index';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  return locales.flatMap((lang) => 
    posts.map((post) => ({
      params: { lang, slug: post.slug },
      props: { post },
    }))
  );
}

const { lang } = Astro.params;
const locale = lang as Locale;
const { post } = Astro.props;
const { Content, headings } = await post.render();

// Build TOC from headings (h2 and h3)
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);

// Fetch related posts (same category, newest first, exclude current, max 3)
const rawPosts = await getCollection('blog');
const relatedPosts = rawPosts
  .filter(p => p.data.category === post.data.category && p.slug !== post.slug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout locale={locale} pageKey="blog" currentPath={`/${locale}/blog/${post.slug}/`}>
  <!-- Hero Section — Split Layout -->
  <section class="blog-hero-section">
    <div class="container-custom">
      <!-- Breadcrumb -->
      <a href={`/${locale}/blog/`} class="blog-breadcrumb reveal">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {t(locale, 'blog.backToBlog')}
      </a>

      <div class="blog-hero-grid">
        <!-- Left: Title & Meta -->
        <div class="blog-hero-content reveal">
          <span class="blog-hero-category">
            {t(locale, `blog.category.${post.data.category}` as any)}
          </span>
          <h1 class="blog-hero-title">
            {post.data.title}
          </h1>
          <p class="blog-hero-description">
            {post.data.description}
          </p>
          <div class="blog-hero-meta">
            <span class="blog-hero-date-label">{t(locale, 'blog.publishDate')}</span>
            <time datetime={post.data.date.toISOString()} class="blog-hero-date">
              {post.data.date.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
        </div>

        <!-- Right: Featured Image -->
        {post.data.image && (
          <div class="blog-hero-image reveal reveal-delay-1">
            <img 
              src={post.data.image} 
              alt={post.data.title} 
              class="blog-hero-img"
              loading="eager"
            />
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Article Body — with optional TOC sidebar -->
  <section class="blog-body-section">
    <div class="container-custom blog-body-layout">
      <!-- Sidebar TOC -->
      {toc.length > 2 && (
        <aside class="blog-toc reveal">
          <div class="blog-toc-sticky">
            <h4 class="blog-toc-title">{t(locale, 'blog.toc')}</h4>
            <nav>
              <ul class="blog-toc-list">
                {toc.map((heading) => (
                  <li class={heading.depth === 3 ? 'blog-toc-sub' : ''}>
                    <a href={`#${heading.slug}`} class="blog-toc-link">
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}

      <!-- Article Content -->
      <article class={`blog-article-content reveal reveal-delay-1 ${toc.length > 2 ? '' : 'blog-article-full'}`}>
        <div class="prose prose-invert prose-lg max-w-none
          prose-headings:text-(--color-text-primary)
          prose-headings:font-bold
          prose-headings:tracking-tight
          prose-p:text-(--color-text-secondary)
          prose-p:leading-relaxed
          prose-a:text-(--color-accent-500)
          prose-a:no-underline
          hover:prose-a:underline
          prose-strong:text-(--color-text-primary)
          prose-code:text-(--color-accent-500)
          prose-code:bg-(--color-surface)
          prose-code:px-1.5
          prose-code:py-0.5
          prose-code:rounded-md
          prose-code:text-sm
          prose-pre:bg-(--color-bg-alt)
          prose-pre:border
          prose-pre:border-(--color-border)
          prose-pre:rounded-xl
          prose-li:text-(--color-text-secondary)
          prose-li:leading-relaxed
          prose-blockquote:border-l-(--color-accent-500)
          prose-blockquote:text-(--color-text-secondary)
          prose-h2:text-2xl
          prose-h2:md:text-3xl
          prose-h2:mt-12
          prose-h2:mb-4
          prose-h3:text-xl
          prose-h3:md:text-2xl
          prose-h3:mt-8
          prose-h3:mb-3
          prose-p:text-base
          prose-p:md:text-lg
          prose-img:rounded-xl
          prose-img:shadow-lg
        ">
          <Content />
        </div>
      </article>
    </div>
  </section>

  <!-- Related Articles -->
  {relatedPosts.length > 0 && (
    <section class="related-articles-section">
      <div class="container-custom">
        <h3 class="related-articles-title reveal">{t(locale, 'blog.related')}</h3>
        <div class="blog-grid" id="related-grid">
          {relatedPosts.map((related, i) => (
            <article class={`blog-card reveal reveal-delay-${Math.min(i + 1, 4)}`}>
              <div class="blog-card-image-wrapper">
                {related.data.image ? (
                  <img src={related.data.image} alt={related.data.title} class="blog-card-image" loading="lazy" decoding="async" />
                ) : (
                  <div class="blog-card-placeholder">
                    <svg class="blog-card-placeholder-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" /></svg>
                  </div>
                )}
              </div>
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <span class="blog-card-category">{t(locale, `blog.category.${related.data.category}` as any)}</span>
                  <time class="blog-card-date" datetime={related.data.date.toISOString()}>
                    {related.data.date.toLocaleDateString(locale, { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                </div>
                <h4 class="blog-card-title">
                  <a href={`/${locale}/blog/${related.slug}/`} class="blog-card-link">{related.data.title}</a>
                </h4>
                <p class="blog-card-description">{related.data.description}</p>
                <span class="blog-card-readmore">
                  {t(locale, 'blog.readMore')}
                  <svg class="blog-card-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Back to Blog — Bottom -->
  <section class="blog-bottom-nav">
    <div class="container-custom">
      <div class="blog-bottom-nav-inner reveal">
        <a href={`/${locale}/blog/`} class="blog-bottom-link">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          {t(locale, 'blog.backToBlog')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Blog Hero Section ────────────────────────────────────── */
  .blog-hero-section {
    padding-top: 7rem;
    padding-bottom: 3rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .blog-hero-section {
      padding-top: 9rem;
      padding-bottom: 4rem;
    }
  }

  .blog-breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s ease;
  }

  .blog-breadcrumb:hover {
    color: var(--color-accent-500);
  }

  .blog-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .blog-hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .blog-hero-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .blog-hero-category {
    display: inline-block;
    width: fit-content;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent-500);
    background: color-mix(in srgb, var(--color-accent-500) 10%, transparent);
    border-radius: 9999px;
  }

  .blog-hero-title {
    font-size: 1.875rem;
    line-height: 1.2;
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .blog-hero-title {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .blog-hero-title {
      font-size: 2.75rem;
    }
  }

  .blog-hero-description {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 540px;
  }

  @media (min-width: 768px) {
    .blog-hero-description {
      font-size: 1.125rem;
    }
  }

  .blog-hero-meta {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-top: 0.5rem;
  }

  .blog-hero-date-label {
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  .blog-hero-date {
    font-size: 0.95rem;
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .blog-hero-image {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.15);
    border: 1px solid var(--color-border);
  }

  .blog-hero-img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
  }

  /* ─── Blog Body ────────────────────────────────────────────── */
  .blog-body-section {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .blog-body-section {
      padding-top: 4rem;
      padding-bottom: 5rem;
    }
  }

  .blog-body-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .blog-body-layout {
      grid-template-columns: 240px 1fr;
      gap: 4rem;
    }
  }

  /* ─── TOC Sidebar ──────────────────────────────────────────── */
  .blog-toc {
    display: none;
  }

  @media (min-width: 1024px) {
    .blog-toc {
      display: block;
    }
  }

  .blog-toc-sticky {
    position: sticky;
    top: 6rem;
  }

  .blog-toc-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-500);
    margin-bottom: 1rem;
  }

  .blog-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blog-toc-link {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    line-height: 1.4;
    transition: color 0.2s ease;
    display: block;
    padding: 0.25rem 0;
  }

  .blog-toc-link:hover {
    color: var(--color-accent-500);
  }

  .blog-toc-sub {
    padding-left: 1rem;
  }

  .blog-toc-sub .blog-toc-link {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
  }

  /* ─── Full width article when no TOC ───────────────────────── */
  .blog-article-full {
    max-width: 48rem;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .blog-body-layout:has(.blog-article-full) {
      grid-template-columns: 1fr;
    }
  }

  /* ─── Bottom Navigation ────────────────────────────────────── */
  .blog-bottom-nav {
    padding-bottom: 4rem;
  }

  .blog-bottom-nav-inner {
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .blog-bottom-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .blog-bottom-link:hover {
    color: var(--color-accent-500);
  }

  /* ─── Related Articles ─────────────────────────────────────── */
  .related-articles-section {
    padding-top: 4rem;
    padding-bottom: 2rem;
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg-alt);
  }

  .related-articles-title {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin-bottom: 2rem;
  }

  /* ─── Blog Grid & Card (Reused from index) ─────────────────── */
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  .blog-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.15);
    border-color: color-mix(in srgb, var(--color-accent-500) 30%, transparent);
  }

  .blog-card-image-wrapper {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface);
  }

  .blog-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card:hover .blog-card-image {
    transform: scale(1.05);
  }

  .blog-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-card-placeholder-icon {
    width: 3rem;
    height: 3rem;
    color: var(--color-text-tertiary);
    opacity: 0.2;
  }

  .blog-card-body {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 1.5rem;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .blog-card-category {
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-accent-500);
    background: color-mix(in srgb, var(--color-accent-500) 10%, transparent);
    border-radius: 0.375rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .blog-card-date {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .blog-card-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-text-primary);
    margin-bottom: 0.625rem;
    transition: color 0.2s ease;
  }

  .blog-card:hover .blog-card-title {
    color: var(--color-accent-500);
  }

  .blog-card-link {
    text-decoration: none;
    color: inherit;
  }

  .blog-card-link::before {
    content: '';
    position: absolute;
    inset: 0;
  }

  .blog-card-description {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex-grow: 1;
  }

  .blog-card-readmore {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent-500);
    transition: color 0.2s ease;
    margin-top: auto;
  }

  .blog-card:hover .blog-card-readmore {
    color: var(--color-accent-600);
  }

  .blog-card-arrow {
    width: 0.875rem;
    height: 0.875rem;
    transition: transform 0.2s ease;
  }

  .blog-card:hover .blog-card-arrow {
    transform: translateX(4px);
  }
</style>
