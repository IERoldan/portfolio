---
/**
 * Chatbot — Asistente flotante de ventas con Gemini AI
 *
 * - Botón flotante bottom-right con animación Lottie
 * - Panel expandible con chat
 * - Soporte multiidioma (detecta locale de la página)
 * - Quick-reply buttons para intent inicial
 * - CTA buttons para Cal.com y WhatsApp
 * - Lead capture (nombre + email) con pre-fill Cal.com
 * - Glassmorphism acorde al portfolio
 * - Historial de conversación
 */
---

<!-- Floating Chat Button -->
<button
  id="chatbot-toggle"
  data-event="chatbot_open"
  class="fixed bottom-6 right-6 z-50 w-28 h-28 rounded-full bg-transparent transition-all duration-300 cursor-pointer flex items-end justify-center group"
  aria-label="Open chat"
>
  <!-- Chat icon (Lottie Animation) -->
  <dotlottie-player
    id="chat-icon-open"
    class="w-full h-full scale-[1.3] -translate-y-2 origin-bottom transition-transform duration-300 group-hover:scale-[1.4] drop-shadow-[0_8px_16px_rgba(0,0,0,0.3)] dark:drop-shadow-[0_0_25px_rgba(59,130,246,0.5)]"
    src="/img/AI%20bot.lottie"
    background="transparent"
    speed="1"
    loop
    autoplay
  ></dotlottie-player>
  <!-- Close icon -->
  <svg id="chat-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
  </svg>
</button>

<!-- DotLottie Local -->
<script src="/libs/dotlottie-player.mjs" type="module"></script>

<!-- Chat Panel -->
<div
  id="chatbot-panel"
  class="fixed bottom-24 right-6 z-50 w-[360px] max-w-[calc(100vw-2rem)] rounded-2xl overflow-hidden shadow-2xl shadow-black/20 opacity-0 invisible translate-y-4 scale-95 transition-all duration-300"
  style="max-height: calc(100vh - 140px);"
>
  <!-- Header -->
  <div class="bg-(--color-accent-500) px-5 py-4 flex items-center gap-3">
    <div class="w-10 h-10 flex items-center justify-center shrink-0 overflow-hidden drop-shadow-md">
      <dotlottie-player
        src="/img/AI%20bot.lottie"
        class="w-12 h-12 object-cover object-bottom"
        background="transparent"
        speed="1"
        loop
        autoplay
      ></dotlottie-player>
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="text-sm font-bold text-white leading-tight">Ivan's AI Assistant</h3>
      <p class="text-[11px] text-white/70" id="chatbot-status">Online</p>
    </div>
    <button id="chatbot-close" class="p-1 text-white/60 hover:text-white transition-colors cursor-pointer" aria-label="Close chat">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Messages -->
  <div
    id="chatbot-messages"
    class="bg-(--color-bg) overflow-y-auto px-4 py-4 space-y-3"
    style="height: 340px;"
  >
    <!-- Welcome message -->
    <div class="chatbot-msg bot flex gap-2.5 items-start">
      <div class="w-8 h-8 flex items-end justify-center shrink-0 mt-0 overflow-hidden">
        <dotlottie-player
          src="/img/AI%20bot.lottie"
          class="w-10 h-10 object-cover object-bottom"
          background="transparent"
          speed="1"
          loop
          autoplay
        ></dotlottie-player>
      </div>
      <div class="bg-(--color-surface) border border-(--color-border) rounded-2xl rounded-tl-md px-3.5 py-2.5 max-w-[85%]">
        <p class="text-[13px] text-(--color-text-primary) leading-relaxed" id="chatbot-welcome">
          👋 ¡Hola! Soy el asistente virtual de Ivan. ¿En qué puedo ayudarte hoy?
        </p>
      </div>
    </div>

    <!-- Quick Reply Buttons -->
    <div id="chatbot-quick-replies" class="flex flex-wrap gap-2 pl-10">
      <button class="quick-reply-btn px-3 py-1.5 text-[12px] font-medium text-(--color-accent-500) bg-(--color-accent-500)/10 border border-(--color-accent-500)/30 rounded-full hover:bg-(--color-accent-500)/20 transition-all duration-200 cursor-pointer" data-event="chatbot_quick_reply" data-message="Quiero contratar un servicio">
        🚀 Contratar un servicio
      </button>
      <button class="quick-reply-btn px-3 py-1.5 text-[12px] font-medium text-(--color-accent-500) bg-(--color-accent-500)/10 border border-(--color-accent-500)/30 rounded-full hover:bg-(--color-accent-500)/20 transition-all duration-200 cursor-pointer" data-event="chatbot_quick_reply" data-message="Me interesa contratar a Ivan para mi equipo">
        💼 Contratar a Ivan
      </button>
      <button class="quick-reply-btn px-3 py-1.5 text-[12px] font-medium text-(--color-accent-500) bg-(--color-accent-500)/10 border border-(--color-accent-500)/30 rounded-full hover:bg-(--color-accent-500)/20 transition-all duration-200 cursor-pointer" data-event="chatbot_quick_reply" data-message="Tengo una pregunta sobre los servicios de Ivan">
        ❓ Tengo una pregunta
      </button>
    </div>
  </div>

  <!-- Cal.com init for chatbot (loads if not already present) -->
  <script is:inline type="text/javascript">
    (function (C, A, L) { var p = function (a, ar) { a.q.push(ar); }; var d = C.document; C.Cal = C.Cal || function () { var cal = C.Cal; var ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement('script')).src = A; cal.loaded = true; } if (ar[0] === L) { var api = function () { p(api, arguments); }; var namespace = ar[1]; api.q = api.q || []; if (typeof namespace === 'string') { cal.ns[namespace] = cal.ns[namespace] || api; p(cal.ns[namespace], ar); p(cal, ['initNamespace', namespace]); } else p(cal, ar); return; } p(cal, ar); }; })(window, 'https://app.cal.com/embed/embed.js', 'init');
    if (!window.__calChatbotInitDone) {
      window.__calChatbotInitDone = true;
      Cal('init', { origin: 'https://cal.com' });
      Cal('ui', {
        styles: { branding: { brandColor: '#3c83f6' } },
        hideEventTypeDetails: false,
        hideBranding: true,
        layout: 'month_view',
        theme: 'dark'
      });
    }
  </script>

  <!-- Input area -->
  <div class="bg-(--color-bg) border-t border-(--color-border) px-4 py-3">
    <form id="chatbot-form" class="flex items-center gap-2">
      <input
        id="chatbot-input"
        type="text"
        placeholder="Escribí tu mensaje..."
        maxlength="500"
        class="flex-1 bg-(--color-surface) border border-(--color-border) rounded-xl px-3.5 py-2.5 text-[13px] text-(--color-text-primary) placeholder:text-(--color-text-tertiary) focus:outline-none focus:border-(--color-accent-500) focus:ring-1 focus:ring-(--color-accent-500)/30 transition-all"
        autocomplete="off"
      />
      <button
        type="submit"
        id="chatbot-send"
        class="shrink-0 w-9 h-9 rounded-xl bg-(--color-accent-500) text-white flex items-center justify-center hover:bg-(--color-accent-600) transition-colors cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
        aria-label="Send"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
        </svg>
      </button>
    </form>
    <p class="text-[10px] text-(--color-text-tertiary) mt-1.5 text-center opacity-60">Máx. 500 caracteres</p>
  </div>
</div>

<script is:inline>
(function() {
  // ─── DOM Elements ─────────────────────────────────────────────
  var toggle = document.getElementById('chatbot-toggle');
  var panel = document.getElementById('chatbot-panel');
  var closeBtn = document.getElementById('chatbot-close');
  var form = document.getElementById('chatbot-form');
  var input = document.getElementById('chatbot-input');
  var messagesContainer = document.getElementById('chatbot-messages');
  var sendBtn = document.getElementById('chatbot-send');
  var iconOpen = document.getElementById('chat-icon-open');
  var iconClose = document.getElementById('chat-icon-close');
  var statusEl = document.getElementById('chatbot-status');
  var quickReplies = document.getElementById('chatbot-quick-replies');

  if (!toggle || !panel || !form || !input || !messagesContainer) return;

  var isOpen = false;
  var isLoading = false;
  var conversationHistory = [];

  // ─── Lead Data Store ──────────────────────────────────────────
  var leadData = { name: '', email: '' };

  // ─── Cal.com & WhatsApp URLs ──────────────────────────────────
  var CAL_BASE_URL = 'https://cal.com/ivan-roldan-drvxar/30min';
  var WHATSAPP_URL = 'https://wa.me/558183342069';

  function getCalUrl() {
    var url = CAL_BASE_URL;
    var params = [];
    if (leadData.name) params.push('name=' + encodeURIComponent(leadData.name));
    if (leadData.email) params.push('email=' + encodeURIComponent(leadData.email));
    if (params.length > 0) url += '?' + params.join('&');
    return url;
  }

  // ─── Toggle Panel ─────────────────────────────────────────────
  function openChat() {
    isOpen = true;
    panel.classList.remove('opacity-0', 'invisible', 'translate-y-4', 'scale-95');
    panel.classList.add('opacity-100', 'visible', 'translate-y-0', 'scale-100');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
    toggle.setAttribute('aria-label', 'Close chat');
    setTimeout(function() { input.focus(); }, 300);
  }

  function closeChat() {
    isOpen = false;
    panel.classList.add('opacity-0', 'invisible', 'translate-y-4', 'scale-95');
    panel.classList.remove('opacity-100', 'visible', 'translate-y-0', 'scale-100');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
    toggle.setAttribute('aria-label', 'Open chat');
  }

  toggle.addEventListener('click', function() {
    isOpen ? closeChat() : openChat();
  });

  if (closeBtn) {
    closeBtn.addEventListener('click', closeChat);
  }

  // ─── Parse CTA Markers ────────────────────────────────────────
  function parseCTAs(text) {
    var ctas = [];
    if (text.indexOf('[CTA:CALENDAR]') !== -1) {
      ctas.push({ type: 'calendar', label: 'Agendar Llamada', url: getCalUrl() });
    }
    if (text.indexOf('[CTA:WHATSAPP]') !== -1) {
      ctas.push({ type: 'whatsapp', label: 'WhatsApp', url: WHATSAPP_URL });
    }

    // Extract lead data if present: [LEAD:name:EMAIL:email]
    var leadMatch = text.match(/\[LEAD:([^:]+):EMAIL:([^\]]+)\]/);
    if (leadMatch) {
      leadData.name = leadMatch[1].trim();
      leadData.email = leadMatch[2].trim();
    }

    // Clean markers from visible text
    var cleanText = text
      .replace(/\[CTA:CALENDAR\]/g, '')
      .replace(/\[CTA:WHATSAPP\]/g, '')
      .replace(/\[LEAD:[^\]]+\]/g, '')
      .trim();

    return { cleanText: cleanText, ctas: ctas };
  }

  // ─── Add Message to UI ────────────────────────────────────────
  function addMessage(text, isUser) {
    var parsed = isUser ? { cleanText: text, ctas: [] } : parseCTAs(text);

    var wrapper = document.createElement('div');
    wrapper.className = 'chatbot-msg ' + (isUser ? 'user' : 'bot') + ' flex gap-2.5 items-start' + (isUser ? ' flex-row-reverse' : '');

    if (!isUser) {
      var avatar = document.createElement('div');
      avatar.className = 'w-8 h-8 flex items-end justify-center shrink-0 mt-0 overflow-hidden';
      avatar.innerHTML = '<dotlottie-player src="/img/AI%20bot.lottie" class="w-10 h-10 object-cover object-bottom" background="transparent" speed="1" loop autoplay></dotlottie-player>';
      wrapper.appendChild(avatar);
    }

    var bubble = document.createElement('div');
    bubble.className = isUser
      ? 'bg-(--color-accent-500) text-white rounded-2xl rounded-tr-md px-3.5 py-2.5 max-w-[85%]'
      : 'bg-(--color-surface) border border-(--color-border) rounded-2xl rounded-tl-md px-3.5 py-2.5 max-w-[85%]';

    var p = document.createElement('p');
    p.className = 'text-[13px] leading-relaxed' + (isUser ? '' : ' text-(--color-text-primary)');

    // Simple markdown: bold, line breaks
    var formatted = parsed.cleanText
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\n/g, '<br>');
    p.innerHTML = formatted;

    bubble.appendChild(p);

    // Add CTA buttons if present
    if (!isUser && parsed.ctas.length > 0) {
      var ctaContainer = document.createElement('div');
      ctaContainer.className = 'w-full flex flex-col gap-2 mt-3';

      parsed.ctas.forEach(function(cta) {
        var btn;
        if (cta.type === 'calendar') {
          // Use Cal.com data-cal-link to open as in-page modal
          btn = document.createElement('button');
          btn.setAttribute('data-cal-link', 'ivan-roldan-drvxar/30min');
          btn.setAttribute('data-cal-config', JSON.stringify({ layout: 'month_view', theme: 'dark' }));
          btn.type = 'button';
          if (leadData.name || leadData.email) {
            var prefill = {};
            if (leadData.name) prefill.name = leadData.name;
            if (leadData.email) prefill.email = leadData.email;
            btn.setAttribute('data-cal-config', JSON.stringify({
              layout: 'month_view',
              theme: 'dark',
              prefill: prefill
            }));
          }
          btn.className = 'flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 text-[12.5px] font-semibold text-white rounded-xl cursor-pointer transition-all duration-200 shadow-md hover:scale-[1.02] active:scale-[0.98] w-full';
          btn.style.background = 'linear-gradient(135deg, #3c83f6 0%, #2563eb 100%)';
          btn.innerHTML = '<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg><span class="truncate">' + cta.label + '</span>';
        } else {
          // WhatsApp — external link
          var waMsg = encodeURIComponent('Hola Ivan, vi tu portfolio y me interesa charlar sobre un proyecto.');
          btn = document.createElement('a');
          btn.href = cta.url + '?text=' + waMsg;
          btn.target = '_blank';
          btn.rel = 'noopener noreferrer';
          btn.className = 'flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 text-[12.5px] font-semibold text-white rounded-xl transition-all duration-200 shadow-md hover:scale-[1.02] active:scale-[0.98] no-underline w-full';
          btn.style.background = 'linear-gradient(135deg, #25d366 0%, #128c7e 100%)';
          btn.innerHTML = '<svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg><span class="truncate">' + cta.label + '</span>';
        }
        ctaContainer.appendChild(btn);
      });

      bubble.appendChild(ctaContainer);
    }

    wrapper.appendChild(bubble);
    messagesContainer.appendChild(wrapper);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  // ─── Typing indicator ─────────────────────────────────────────
  function showTyping() {
    var wrapper = document.createElement('div');
    wrapper.className = 'chatbot-msg bot flex gap-2.5 items-start';
    wrapper.id = 'typing-indicator';

    var avatar = document.createElement('div');
    avatar.className = 'w-8 h-8 flex items-end justify-center shrink-0 mt-0 overflow-hidden';
    avatar.innerHTML = '<dotlottie-player src="/img/AI%20bot.lottie" class="w-10 h-10 object-cover object-bottom" background="transparent" speed="1" loop autoplay></dotlottie-player>';
    wrapper.appendChild(avatar);

    var bubble = document.createElement('div');
    bubble.className = 'bg-(--color-surface) border border-(--color-border) rounded-2xl rounded-tl-md px-4 py-3';
    bubble.innerHTML = '<div class="flex gap-1"><span class="typing-dot w-2 h-2 rounded-full bg-(--color-text-tertiary) animate-bounce" style="animation-delay:0ms"></span><span class="typing-dot w-2 h-2 rounded-full bg-(--color-text-tertiary) animate-bounce" style="animation-delay:150ms"></span><span class="typing-dot w-2 h-2 rounded-full bg-(--color-text-tertiary) animate-bounce" style="animation-delay:300ms"></span></div>';
    wrapper.appendChild(bubble);

    messagesContainer.appendChild(wrapper);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  function hideTyping() {
    var el = document.getElementById('typing-indicator');
    if (el) el.remove();
  }

  // ─── Send Message ─────────────────────────────────────────────
  async function sendMessage(userText) {
    if (isLoading || !userText.trim()) return;

    // Enforce max length on client side too
    if (userText.length > 500) {
      userText = userText.substring(0, 500);
    }

    isLoading = true;
    sendBtn.disabled = true;
    if (statusEl) statusEl.textContent = 'Escribiendo...';

    // Hide quick replies after first message
    if (quickReplies) {
      quickReplies.style.display = 'none';
    }

    // Add user message
    addMessage(userText, true);
    conversationHistory.push({ role: 'user', content: userText });
    input.value = '';

    // Show typing
    showTyping();

    try {
      var response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: conversationHistory }),
      });

      hideTyping();

      if (response.status === 429) {
        addMessage('⏳ Demasiadas solicitudes. Por favor esperá un momento antes de enviar otro mensaje.', false);
        return;
      }

      if (!response.ok) {
        var errorData = await response.json().catch(function() { return {}; });
        throw new Error(errorData.error || 'Server error');
      }

      var data = await response.json();
      var botMessage = data.message || 'Lo siento, no pude procesar tu mensaje.';

      conversationHistory.push({ role: 'assistant', content: botMessage });
      addMessage(botMessage, false);
    } catch (err) {
      hideTyping();
      addMessage('⚠️ Error de conexión. Por favor intentá de nuevo.', false);
      console.error('Chatbot error:', err);
    } finally {
      isLoading = false;
      sendBtn.disabled = false;
      if (statusEl) statusEl.textContent = 'Online';
    }
  }

  // ─── Quick Reply Buttons ──────────────────────────────────────
  if (quickReplies) {
    var qrButtons = quickReplies.querySelectorAll('.quick-reply-btn');
    qrButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var message = btn.getAttribute('data-message');
        if (message) sendMessage(message);
      });
    });
  }

  // ─── Form Submit ──────────────────────────────────────────────
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    sendMessage(input.value);
  });

  // ─── Keyboard shortcut: Escape to close ───────────────────────
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && isOpen) closeChat();
  });
})();
</script>
