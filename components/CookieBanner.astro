---
/**
 * CookieBanner Component
 * 
 * Implementación nativa de Astro/VanillaJS del banner de cookies.
 * Incluye lógica para inyectar/retirar scripts de Google Analytics y FB Pixel.
 */
const { locale = 'es' } = Astro.props;
---

<div id="cookie-banner-container" class="hidden">
  <!-- BANNER INFERIOR -->
  <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[9990] translate-y-full transition-transform duration-400 ease-out">
    <div class="bg-gray-900/95 backdrop-blur-md border-t border-white/10 px-6 py-5">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="flex items-start gap-3 flex-1">
          <svg class="w-6 h-6 text-(--color-accent-500) shrink-0 mt-0.5 md:mt-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"></path></svg>
          <p class="text-white/90 text-sm leading-relaxed m-0">
            Usamos <strong class="text-white">cookies</strong> para mejorar tu experiencia, 
            analizar el tráfico y personalizar contenido.
          </p>
        </div>
        <div class="flex gap-3 flex-wrap shrink-0">
          <button id="btn-cookie-settings" class="px-5 py-2.5 text-sm text-white/80 border border-white/25 rounded-full hover:bg-white/10 transition-all cursor-pointer">
            Configurar
          </button>
          <button id="btn-cookie-accept-all" class="px-7 py-2.5 text-sm text-white font-semibold bg-(--color-accent-500) rounded-full hover:bg-(--color-accent-600) shadow-lg shadow-(--color-accent-500)/30 transition-all cursor-pointer">
            Aceptar todas
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL DE CONFIGURACIÓN -->
  <div id="cookie-settings-modal" class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 p-4">
    <div class="bg-(--color-bg) rounded-2xl max-w-lg w-full shadow-2xl scale-95 transition-transform duration-300 transform" id="cookie-settings-content">
      <!-- Header -->
      <div class="p-5 border-b border-gray-200 dark:border-gray-800">
        <div class="flex items-center gap-2 mb-1">
          <svg class="w-5 h-5 text-(--color-accent-500)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"></path></svg>
          <h2 class="text-base font-bold text-(--color-text-primary) m-0">Configuración de Cookies</h2>
        </div>
        <p class="text-xs text-(--color-text-secondary) leading-relaxed m-0">
          Elegí qué cookies querés aceptar. Las esenciales son necesarias para que el sitio funcione.
        </p>
      </div>

      <!-- Categories -->
      <div class="py-2">
        <!-- Esenciales -->
        <div class="flex items-center gap-3 px-5 py-3 border-b border-gray-100 dark:border-gray-800">
          <svg class="w-5 h-5 text-(--color-accent-500) shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
          <div class="flex-1 min-w-0">
            <p class="text-[13px] font-semibold text-(--color-text-primary) m-0">Esenciales</p>
            <p class="text-[11px] text-(--color-text-secondary) leading-tight mt-0.5 mb-0">Necesarias para el funcionamiento del sitio. No se pueden desactivar.</p>
          </div>
          <div class="w-10 h-6 shrink-0 bg-(--color-accent-500) rounded-full relative opacity-60 cursor-not-allowed">
            <div class="absolute w-4 h-4 bg-white rounded-full top-1 left-[1.125rem] shadow-sm"></div>
          </div>
        </div>

        <!-- Analíticas -->
        <div class="flex items-center gap-3 px-5 py-3 border-b border-gray-100 dark:border-gray-800">
          <svg class="w-5 h-5 text-(--color-accent-500) shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
          <div class="flex-1 min-w-0">
            <p class="text-[13px] font-semibold text-(--color-text-primary) m-0">Analíticas</p>
            <p class="text-[11px] text-(--color-text-secondary) leading-tight mt-0.5 mb-0">Ayudan a entender cómo usás el sitio para mejorarlo (Google Analytics).</p>
          </div>
          <button id="toggle-analytics" class="cookie-toggle w-10 h-6 shrink-0 bg-gray-300 dark:bg-gray-700 rounded-full relative transition-colors cursor-pointer" aria-pressed="false">
            <div class="toggle-dot absolute w-4 h-4 bg-white rounded-full top-1 left-1 transition-all shadow-sm pointer-events-none"></div>
          </button>
        </div>

        <!-- Marketing -->
        <div class="flex items-center gap-3 px-5 py-3">
          <svg class="w-5 h-5 text-(--color-accent-500) shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
          <div class="flex-1 min-w-0">
            <p class="text-[13px] font-semibold text-(--color-text-primary) m-0">Marketing</p>
            <p class="text-[11px] text-(--color-text-secondary) leading-tight mt-0.5 mb-0">Permiten mostrarte anuncios relevantes (Facebook Pixel).</p>
          </div>
          <button id="toggle-marketing" class="cookie-toggle w-10 h-6 shrink-0 bg-gray-300 dark:bg-gray-700 rounded-full relative transition-colors cursor-pointer" aria-pressed="false">
            <div class="toggle-dot absolute w-4 h-4 bg-white rounded-full top-1 left-1 transition-all shadow-sm pointer-events-none"></div>
          </button>
        </div>
      </div>

      <!-- Footer Buttons -->
      <div class="p-4 border-t border-gray-200 dark:border-gray-800 flex gap-3">
        <button id="btn-cookie-reject-all" class="flex-1 py-2.5 px-4 text-sm text-(--color-text-secondary) border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors cursor-pointer">
          Rechazar todo
        </button>
        <button id="btn-cookie-save" class="flex-1 py-2.5 px-4 text-sm text-white font-semibold bg-(--color-accent-500) rounded-lg hover:bg-(--color-accent-600) shadow-md shadow-(--color-accent-500)/20 transition-all cursor-pointer">
          Guardar preferencias
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const CONSENT_KEY = 'portfolio_cookie_consent';
  
  // Default tracking scripts placeholders
  const GA_MEASUREMENT_ID = 'G-XXXXXXXXXX';
  const FB_PIXEL_ID = 'XXXXXXXXXXXXXXX';

  // Elements
  const container = document.getElementById('cookie-banner-container');
  const banner = document.getElementById('cookie-banner');
  const modal = document.getElementById('cookie-settings-modal');
  const modalContent = document.getElementById('cookie-settings-content');
  
  const btnSettings = document.getElementById('btn-cookie-settings');
  const btnAcceptAllBanner = document.getElementById('btn-cookie-accept-all');
  const btnRejectAllModal = document.getElementById('btn-cookie-reject-all');
  const btnSaveModal = document.getElementById('btn-cookie-save');
  
  const toggleAnalytics = document.getElementById('toggle-analytics');
  const toggleMarketing = document.getElementById('toggle-marketing');

  // State
  let prefs = {
    essential: true,
    analytics: false,
    marketing: false
  };

  // Logic
  function init() {
    const stored = localStorage.getItem(CONSENT_KEY);
    if (!stored) {
      // Show banner
      if(container) container.classList.remove('hidden');
      setTimeout(() => {
        if(banner) banner.classList.remove('translate-y-full');
      }, 150);
    } else {
      try {
        prefs = JSON.parse(stored);
        applyPreferences(prefs);
      } catch (e) {
        // Corrupted cache - show banner
        if(container) container.classList.remove('hidden');
        setTimeout(() => {
          if(banner) banner.classList.remove('translate-y-full');
        }, 150);
      }
    }
  }

  function hideAll() {
    if(banner) banner.classList.add('translate-y-full');
    if(modal) {
        modal.classList.remove('opacity-100', 'pointer-events-auto');
        modal.classList.add('opacity-0', 'pointer-events-none');
    }
    if(modalContent) {
        modalContent.classList.remove('scale-100');
        modalContent.classList.add('scale-95');
    }
    setTimeout(() => {
      if(container) container.classList.add('hidden');
    }, 400);
  }

  function showModal() {
    // Load current prefs to toggles
    updateToggleInfo(toggleAnalytics, prefs.analytics);
    updateToggleInfo(toggleMarketing, prefs.marketing);
    
    if (modal) {
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modal.classList.add('opacity-100', 'pointer-events-auto');
    }
    if (modalContent) {
        modalContent.classList.remove('scale-95');
        modalContent.classList.add('scale-100');
    }
  }

  function hideModal() {
    if (modal) {
        modal.classList.remove('opacity-100', 'pointer-events-auto');
        modal.classList.add('opacity-0', 'pointer-events-none');
    }
    if (modalContent) {
        modalContent.classList.remove('scale-100');
        modalContent.classList.add('scale-95');
    }
  }

  function updateToggleInfo(btn, isActive) {
    if(!btn) return;
    btn.setAttribute('aria-pressed', isActive.toString());
    const dot = btn.querySelector('.toggle-dot');
    if(isActive) {
      btn.style.backgroundColor = 'var(--color-accent-500)';
      if(dot) dot.style.transform = 'translateX(1.1rem)';
    } else {
      btn.style.backgroundColor = ''; 
      if(dot) dot.style.transform = 'translateX(0)';
    }
  }

  function toggleBtnState(btn) {
    if(!btn) return false;
    const currentState = btn.getAttribute('aria-pressed') === 'true';
    const newState = !currentState;
    updateToggleInfo(btn, newState);
    return newState;
  }

  function savePreferences(newPrefs) {
    localStorage.setItem(CONSENT_KEY, JSON.stringify(newPrefs));
    applyPreferences(newPrefs);
    hideAll();
  }

  function applyPreferences(p) {
    if (p.analytics) loadGoogleAnalytics();
    else removeGoogleAnalytics();

    if (p.marketing) loadFacebookPixel();
    else removeFacebookPixel();
  }

  // --- Tracking Scripts Subroutines ---
  function loadGoogleAnalytics() {
    if (document.querySelector('script[src*="gtag/js?id=' + GA_MEASUREMENT_ID + '"]')) return;
    if (GA_MEASUREMENT_ID === 'G-XXXXXXXXXX') {
      console.log('Google Analytics loaded (Placeholder ID)');
      return;
    }
    const script = document.createElement('script');
    script.async = true;
    script.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_MEASUREMENT_ID;
    script.setAttribute('data-consent', 'analytics');
    document.head.appendChild(script);

    const inlineScript = document.createElement('script');
    inlineScript.setAttribute('data-consent', 'analytics');
    inlineScript.textContent = 
      "window.dataLayer = window.dataLayer || [];\n" +
      "function gtag(){dataLayer.push(arguments);}\n" +
      "gtag('js', new Date());\n" +
      "gtag('config', '" + GA_MEASUREMENT_ID + "');";
    document.head.appendChild(inlineScript);
  }

  function removeGoogleAnalytics() {
    document.querySelectorAll('script[data-consent="analytics"]').forEach(el => el.remove());
    document.cookie.split(';').forEach(cookie => {
      const name = cookie.split('=')[0].trim();
      if (name.startsWith('_ga') || name.startsWith('_gid')) {
        document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=' + window.location.hostname;
        document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
      }
    });
  }

  function loadFacebookPixel() {
    if (window.fbq) return;
    if (FB_PIXEL_ID === 'XXXXXXXXXXXXXXX') {
      console.log('Facebook Pixel loaded (Placeholder ID)');
      return;
    }
    const script = document.createElement('script');
    script.setAttribute('data-consent', 'marketing');
    script.textContent = 
      "!function(f,b,e,v,n,t,s)\n" +
      "{if(f.fbq)return;n=f.fbq=function(){n.callMethod?\n" +
      "n.callMethod.apply(n,arguments):n.queue.push(arguments)};\n" +
      "if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';\n" +
      "n.queue=[];t=b.createElement(e);t.async=!0;\n" +
      "t.src=v;s=b.getElementsByTagName(e)[0];\n" +
      "s.parentNode.insertBefore(t,s)}(window, document,'script',\n" +
      "'https://connect.facebook.net/en_US/fbevents.js');\n" +
      "fbq('init', '" + FB_PIXEL_ID + "');\n" +
      "fbq('track', 'PageView');";
    document.head.appendChild(script);
  }

  function removeFacebookPixel() {
    document.querySelectorAll('script[data-consent="marketing"]').forEach(el => el.remove());
    delete window.fbq;
    delete window._fbq;
  }

  // --- Event Listeners ---
  if(btnAcceptAllBanner) {
    btnAcceptAllBanner.addEventListener('click', () => {
      savePreferences({ essential: true, analytics: true, marketing: true });
    });
  }

  if(btnSettings) {
    btnSettings.addEventListener('click', () => {
      showModal();
    });
  }

  if(toggleAnalytics) {
    toggleAnalytics.addEventListener('click', (e) => toggleBtnState(e.currentTarget));
  }
  if(toggleMarketing) {
    toggleMarketing.addEventListener('click', (e) => toggleBtnState(e.currentTarget));
  }

  if(btnRejectAllModal) {
    btnRejectAllModal.addEventListener('click', () => {
      savePreferences({ essential: true, analytics: false, marketing: false });
    });
  }

  if(btnSaveModal) {
    btnSaveModal.addEventListener('click', () => {
      const analytics = toggleAnalytics?.getAttribute('aria-pressed') === 'true';
      const marketing = toggleMarketing?.getAttribute('aria-pressed') === 'true';
      savePreferences({ essential: true, analytics, marketing });
    });
  }
  
  // Close modal when clicking outside
  if(modal) {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        hideModal();
      }
    });
  }

  // Init on load
  init();
</script>
