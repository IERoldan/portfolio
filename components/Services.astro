---
/**
 * Services Section
 *
 * - Label + título
 * - 4 cards en grid con iconos SVG
 * - Hover: lift + accent border glow
 * - Scroll reveal animation
 */
import { t, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const services = [
  {
    titleKey: 'services.react.title',
    descKey: 'services.react.description',
    tagsKey: 'services.react.tags',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />`,
  },
  {
    titleKey: 'services.webflow.title',
    descKey: 'services.webflow.description',
    tagsKey: 'services.webflow.tags',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />`,
  },
  {
    titleKey: 'services.seo.title',
    descKey: 'services.seo.description',
    tagsKey: 'services.seo.tags',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />`,
  },
  {
    titleKey: 'services.backend.title',
    descKey: 'services.backend.description',
    tagsKey: 'services.backend.tags',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" />`,
  },
  {
    titleKey: 'services.ai.title',
    descKey: 'services.ai.description',
    tagsKey: 'services.ai.tags',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09l2.846.813-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />`,
  },
];
---

<section id="services" class="py-20 md:py-28 bg-(--color-bg-alt)">
  <div class="container-custom">
    <!-- Section header -->
    <div class="text-center mb-14 md:mb-20">
      <span class="reveal inline-block px-3 py-1 text-xs font-semibold text-(--color-accent-500) bg-(--color-accent-500)/10 rounded-full uppercase tracking-wider mb-4">
        {t(locale, 'services.label')}
      </span>
      <h2 class="reveal reveal-delay-1 text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight">
        {t(locale, 'services.title')}
      </h2>
    </div>

    <!-- Services grid -->
    <div class="flex flex-wrap justify-center gap-6">
      {services.map((service, i) => (
        <div class={`reveal reveal-delay-${i + 1} group relative p-6 md:p-8 bg-(--color-bg) border border-(--color-border) rounded-2xl transition-all duration-300 hover:-translate-y-1 hover:border-(--color-accent-500)/40 hover:shadow-xl hover:shadow-(--color-accent-500)/5 w-full sm:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)]`}>
          <!-- Icon -->
          <div class="w-12 h-12 flex items-center justify-center bg-(--color-accent-500)/10 text-(--color-accent-500) rounded-xl mb-5 group-hover:bg-(--color-accent-500)/20 transition-colors duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={service.icon} />
          </div>

          <!-- Title -->
          <h3 class="text-base sm:text-lg font-semibold mb-3 text-(--color-text-primary) tracking-tight break-words">
            {t(locale, service.titleKey)}
          </h3>

          <!-- Description -->
          <p class="text-sm text-(--color-text-secondary) leading-relaxed">
            {t(locale, service.descKey)}
          </p>

          <!-- Tags -->
          <div class="mt-5 flex flex-wrap gap-2">
            {t(locale, service.tagsKey).split(',').map(tag => (
              <span class="px-2.5 py-1 text-xs font-medium text-(--color-accent-600) dark:text-(--color-accent-400) bg-(--color-accent-500)/10 rounded-full">
                {tag.trim()}
              </span>
            ))}
          </div>

          <div class="absolute bottom-0 left-6 right-6 h-0.5 bg-(--color-accent-500) rounded-full scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>
</section>
