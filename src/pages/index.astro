---
/**
 * Root redirect — Detección de locale server-side
 *
 * Lee el header Accept-Language del navegador.
 * - Español: todos los países de LATAM + España + Guinea Ecuatorial
 * - Portugués: Brasil, Portugal, Angola, Mozambique, Cabo Verde, São Tomé, Guinea-Bissau
 * - Inglés: todo lo demás (default)
 */
export const prerender = false;

import type { APIContext } from 'astro';

// Códigos de país (region) que usan español como idioma principal
const SPANISH_REGIONS = new Set([
  'es', // España
  'mx', // México
  'ar', // Argentina
  'co', // Colombia
  'pe', // Perú
  've', // Venezuela
  'cl', // Chile
  'ec', // Ecuador
  'gt', // Guatemala
  'cu', // Cuba
  'bo', // Bolivia
  'do', // República Dominicana
  'hn', // Honduras
  'py', // Paraguay
  'sv', // El Salvador
  'ni', // Nicaragua
  'cr', // Costa Rica
  'pa', // Panamá
  'uy', // Uruguay
  'gq', // Guinea Ecuatorial
  'pr', // Puerto Rico
  'us', // es-US (comunidades latinas)
]);

// Códigos de país (region) que usan portugués como idioma principal
const PORTUGUESE_REGIONS = new Set([
  'br', // Brasil
  'pt', // Portugal
  'ao', // Angola
  'mz', // Mozambique
  'cv', // Cabo Verde
  'st', // São Tomé y Príncipe
  'gw', // Guinea-Bissau
  'tl', // Timor-Leste
]);

function detectLocale(acceptLanguage: string | null): string {
  if (!acceptLanguage) return 'en';

  const langs = acceptLanguage
    .split(',')
    .map(entry => {
      const [tag, q] = entry.trim().split(';q=');
      const [lang, region] = tag.trim().split('-');
      return {
        lang: lang.toLowerCase(),
        region: region?.toLowerCase() ?? '',
        q: q ? parseFloat(q) : 1.0,
      };
    })
    .sort((a, b) => b.q - a.q);

  for (const { lang, region } of langs) {
    if (lang === 'es') {
      // Si tiene región específica, verificar que sea hispana
      if (!region || SPANISH_REGIONS.has(region)) return 'es';
    }
    if (lang === 'pt') {
      if (!region || PORTUGUESE_REGIONS.has(region)) return 'pt';
    }
    if (lang === 'en') return 'en';
  }

  return 'en';
}

export async function GET({ request }: APIContext) {
  const acceptLanguage = request.headers.get('accept-language');
  const locale = detectLocale(acceptLanguage);

  return new Response(null, {
    status: 302,
    headers: {
      'Location': `/${locale}/`,
      'Vary': 'Accept-Language',
    },
  });
}
---
