---
/**
 * Blog & Case Studies page — /{lang}/blog/
 *
 * Grid de blog cards con filtros por categoría.
 * Diseño inspirado en Inconcert CX blog.
 */
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t, locales, type Locale } from '../../../i18n/index';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return locales.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const locale = lang as Locale;

// Fetch posts from Content Collections
const rawPosts = await getCollection('blog');
// Sort by date descending
const posts = rawPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['all', 'casestudy', 'tutorial', 'thoughts'] as const;
---

<BaseLayout locale={locale} pageKey="blog" currentPath={`/${locale}/blog/`}>
  <section class="blog-listing-section">
    <div class="container-custom">
      <!-- Header -->
      <div class="blog-listing-header reveal">
        <span class="blog-listing-label">
          {t(locale, 'blog.label')}
        </span>
        <h1 class="blog-listing-title">
          {t(locale, 'blog.title')}
        </h1>
      </div>

      <!-- Category filters -->
      <div class="blog-filters reveal reveal-delay-1" id="blog-filters">
        {categories.map((cat) => (
          <button
            data-filter={cat}
            class={`blog-filter-btn ${
              cat === 'all' ? 'blog-filter-active' : ''
            }`}
          >
            {t(locale, `blog.category.${cat}`)}
          </button>
        ))}
      </div>

      <!-- Blog grid -->
      <div class="blog-grid" id="blog-grid">
        {posts.map((post, i) => (
          <article
            class={`blog-card reveal reveal-delay-${Math.min(i + 1, 4)}`}
            data-category={post.data.category}
          >
            <!-- Image -->
            <div class="blog-card-image-wrapper">
              {post.data.image ? (
                <img 
                  src={post.data.image} 
                  alt={post.data.title} 
                  class="blog-card-image"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="blog-card-placeholder">
                  <svg class="blog-card-placeholder-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />
                  </svg>
                </div>
              )}
            </div>

            <!-- Content -->
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <span class="blog-card-category">
                  {t(locale, `blog.category.${post.data.category}` as any)}
                </span>
                <time class="blog-card-date" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString(locale, { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>

              <h2 class="blog-card-title">
                <a href={`/${locale}/blog/${post.slug}/`} class="blog-card-link">
                  {post.data.title}
                </a>
              </h2>

              <p class="blog-card-description">
                {post.data.description}
              </p>

              <span class="blog-card-readmore">
                {t(locale, 'blog.readMore')}
                <svg class="blog-card-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Blog Listing Section ─────────────────────────────────── */
  .blog-listing-section {
    padding-top: 7rem;
    padding-bottom: 5rem;
  }

  @media (min-width: 768px) {
    .blog-listing-section {
      padding-top: 9rem;
      padding-bottom: 7rem;
    }
  }

  .blog-listing-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .blog-listing-label {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent-500);
    background: color-mix(in srgb, var(--color-accent-500) 10%, transparent);
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .blog-listing-title {
    font-size: 1.875rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  @media (min-width: 768px) {
    .blog-listing-title {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .blog-listing-title {
      font-size: 3rem;
    }
  }

  /* ─── Filters ──────────────────────────────────────────────── */
  .blog-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .blog-filter-btn {
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    color: var(--color-text-secondary);
    background: var(--color-surface);
  }

  .blog-filter-btn:hover {
    color: var(--color-text-primary);
    background: var(--color-surface-hover);
  }

  .blog-filter-btn.blog-filter-active {
    background: var(--color-accent-500);
    color: white;
  }

  /* ─── Blog Grid ────────────────────────────────────────────── */
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  /* ─── Blog Card ────────────────────────────────────────────── */
  .blog-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.15);
    border-color: color-mix(in srgb, var(--color-accent-500) 30%, transparent);
  }

  /* ─── Card Image ───────────────────────────────────────────── */
  .blog-card-image-wrapper {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface);
  }

  .blog-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card:hover .blog-card-image {
    transform: scale(1.05);
  }

  .blog-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-card-placeholder-icon {
    width: 3rem;
    height: 3rem;
    color: var(--color-text-tertiary);
    opacity: 0.2;
  }

  /* ─── Card Body ────────────────────────────────────────────── */
  .blog-card-body {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 1.5rem;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .blog-card-category {
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-accent-500);
    background: color-mix(in srgb, var(--color-accent-500) 10%, transparent);
    border-radius: 0.375rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .blog-card-date {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .blog-card-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-text-primary);
    margin-bottom: 0.625rem;
    transition: color 0.2s ease;
  }

  .blog-card:hover .blog-card-title {
    color: var(--color-accent-500);
  }

  .blog-card-link {
    text-decoration: none;
    color: inherit;
  }

  /* Make the entire card clickable via the link */
  .blog-card-link::before {
    content: '';
    position: absolute;
    inset: 0;
  }

  .blog-card-description {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex-grow: 1;
  }

  .blog-card-readmore {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent-500);
    transition: color 0.2s ease;
    margin-top: auto;
  }

  .blog-card:hover .blog-card-readmore {
    color: var(--color-accent-600);
  }

  .blog-card-arrow {
    width: 0.875rem;
    height: 0.875rem;
    transition: transform 0.2s ease;
  }

  .blog-card:hover .blog-card-arrow {
    transform: translateX(4px);
  }
</style>

<!-- Blog filter script -->
<script is:inline>
  (function() {
    var filters = document.getElementById('blog-filters');
    var grid = document.getElementById('blog-grid');
    if (!filters || !grid) return;

    var buttons = filters.querySelectorAll('[data-filter]');
    var cards = grid.querySelectorAll('[data-category]');

    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var filter = btn.getAttribute('data-filter');

        // Update active button
        buttons.forEach(function(b) {
          b.classList.remove('blog-filter-active');
        });
        btn.classList.add('blog-filter-active');

        // Filter cards
        cards.forEach(function(card) {
          if (filter === 'all' || card.getAttribute('data-category') === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  })();
</script>
