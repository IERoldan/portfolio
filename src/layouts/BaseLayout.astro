---
/**
 * BaseLayout — Layout principal del portfolio
 *
 * Incluye:
 * - SEO Head con meta tags por locale
 * - hreflang alternates para i18n
 * - Open Graph & Twitter Card
 * - JSON-LD structured data
 * - Theme script (dark/light mode)
 * - Header y Footer
 */
import Header from '../components/Header.astro';
import Chatbot from '../components/Chatbot.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import BaseHead from '../components/BaseHead.astro';
import { t, locales, type Locale } from '../i18n/index';
import '../styles/global.css';

interface Props {
  locale: Locale;
  pageKey?: string; // fallback
  currentPath: string;
  // New override props
  seoTitle?: string;
  seoDescription?: string;
  image?: string;
  canonicalUrl?: URL;
  noindex?: boolean;
  alternates?: Record<string, string>;
  isBlogPost?: boolean;
  publishDate?: Date;
}

const { 
  locale, 
  pageKey = 'home', 
  currentPath,
  seoTitle: overrideTitle,
  seoDescription: overrideDescription,
  image,
  canonicalUrl: overrideCanonicalUrl,
  noindex,
  alternates: overrideAlternates,
  isBlogPost,
  publishDate
} = Astro.props;

// SEO metadata por página y locale con overrides
const seoTitle = overrideTitle || t(locale, `seo.${pageKey}.title` as any);
const seoDescription = overrideDescription || t(locale, `seo.${pageKey}.description` as any);
const canonicalUrl = overrideCanonicalUrl || new URL(currentPath, Astro.site);

// Hreflang alternates fallback genérico si no se envían
let alternates = overrideAlternates;
if (!alternates) {
  alternates = {};
  locales.forEach((lang) => {
    const segments = currentPath.split('/').filter(Boolean);
    if (segments.length > 0) segments[0] = lang;
    else segments.unshift(lang);
    alternates![lang] = new URL('/' + segments.join('/') + '/', Astro.site).href;
  });
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead
      title={seoTitle}
      description={seoDescription}
      image={image}
      canonicalUrl={canonicalUrl}
      locale={locale}
      noindex={noindex}
      alternates={alternates}
      isBlogPost={isBlogPost}
      publishDate={publishDate}
    />

    <!-- Theme: aplicar antes del render para evitar FOUC -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        // Default: light. Solo aplica dark si el usuario lo guardó explícitamente
        // o si su sistema operativo prefiere dark y nunca eligió manualmente.
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored ? stored === 'dark' : prefersDark;
        if (isDark) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="bg-(--color-bg) text-(--color-text-primary) font-sans min-h-screen flex flex-col transition-colors duration-300">
    <Header locale={locale} currentPath={currentPath} alternates={alternates} />

    <main class="flex-1">
      <slot />
    </main>

    <Footer locale={locale} />

    <Chatbot />
    <CookieBanner />

    <!-- Scripts de animación — cargados al final para no bloquear render -->
    <script src="../scripts/typewriter.ts"></script>
    <script src="../scripts/scroll-effects.ts"></script>
  </body>
</html>
