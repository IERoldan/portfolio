---
/**
 * Hero Section
 *
 * - Typewriter effect en el título
 * - Parallax suave en la foto
 * - Stats bar
 * - 2 CTA buttons
 * - Responsive: stacked en mobile
 */
import { t, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="home" class="relative pt-28 md:pt-30 overflow-hidden">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-(--color-accent-500)/5 via-transparent to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="container-custom relative h-full">
    <div class="grid lg:grid-cols-[1.25fr_1fr] gap-12 lg:gap-16">

      <!-- Text Content -->
      <div class="order-2 lg:order-1 flex flex-col items-center lg:items-start justify-center pb-12 lg:pb-20">
        <!-- Greeting badge -->
        <div class="reveal inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-sm font-medium text-(--color-accent-500) bg-(--color-accent-500)/10 rounded-full border border-(--color-accent-500)/20">
          <span class="w-2 h-2 bg-(--color-accent-500) rounded-full animate-pulse"></span>
          {t(locale, 'hero.greeting')}
        </div>

        <!-- Main title with typewriter -->
        <h1 class="reveal reveal-delay-1 text-4xl sm:text-4xl lg:text-5xl xl:text-[3.75rem] font-bold leading-tight tracking-tight mb-6 line-clamp-2 w-full text-center lg:text-left">
          <span
            data-typewriter={JSON.stringify([
              t(locale, 'hero.title.1'),
              t(locale, 'hero.title.2'),
              t(locale, 'hero.title.3'),
              t(locale, 'hero.title.4')
            ])}
            data-typewriter-speed="60"
            class="gradient-text"
          >
            {t(locale, 'hero.title.1')}
          </span>
        </h1>

        <!-- Subtitle -->
        <p class="reveal reveal-delay-2 text-base md:text-lg text-(--color-text-secondary) font-light leading-relaxed mb-8 max-w-xl text-center lg:text-left">
          {t(locale, 'hero.subtitle')}
        </p>

        <!-- CTA Buttons -->
        <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 mb-8 lg:mb-0 items-stretch sm:items-center">
          <a
            href={`/${locale}/#projects`}
            data-event="hero_cta_primary"
            class="flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-(--color-accent-500) hover:bg-(--color-accent-600) rounded-xl transition-all duration-200 shadow-lg shadow-(--color-accent-500)/25 hover:shadow-xl hover:shadow-(--color-accent-500)/30 hover:-translate-y-0.5"
          >
            {t(locale, 'hero.cta.work')}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href={`/${locale}/#contact`}
            data-event="hero_cta_secondary"
            class="flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-(--color-text-primary) bg-(--color-surface) hover:bg-(--color-surface-hover) border border-(--color-border) rounded-xl transition-all duration-200 hover:-translate-y-0.5"
          >
            {t(locale, 'hero.cta.contact')}
          </a>
        </div>
      </div>

      <!-- Profile Image with Circular Halo and Floating Stats -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end items-end lg:-mr-4 self-end">
        <div class="relative w-[320px] h-[320px] sm:w-[400px] sm:h-[400px] md:w-[450px] md:h-[450px] lg:w-[500px] lg:h-[500px]">
          
          <!-- Outer Glow -->
          <div 
            class="absolute inset-0 bg-gradient-to-tr from-(--color-accent-400)/30 to-(--color-accent-600)/30 rounded-full blur-3xl opacity-50 z-0" 
            aria-hidden="true"
          ></div>

          <!-- Image floating in front of the circle, anchored to bottom -->
          <div class="absolute inset-0 z-10 flex items-end justify-center">
             <img 
              src="/img/ivan_img.webp" 
              alt="Ivan" 
              class="block w-[75%] max-h-full h-auto object-contain object-bottom drop-shadow-[0_20px_20px_rgba(0,0,0,0.5)]"
             >
          </div>

          <!-- Floating Stat 1: Webflow / CMS -->
          <div class="absolute top-[8%] -left-2 sm:-left-6 md:-left-10 bg-(--color-surface)/80 backdrop-blur-lg border border-(--color-border) px-4 py-3 rounded-xl shadow-xl shadow-black/5 z-20 reveal reveal-delay-2 hover:-translate-y-1 transition-transform duration-300">
            <div class="text-sm md:text-base font-bold text-(--color-text-primary)">{t(locale, 'hero.badges.1.title')}</div>
            <div class="text-[10px] md:text-xs font-semibold text-(--color-accent-500) uppercase tracking-wider">{t(locale, 'hero.badges.1.subtitle')}</div>
          </div>

          <!-- Floating Stat 2: AI / Auto -->
          <div class="absolute top-[40%] -right-2 sm:-right-4 md:-right-8 bg-(--color-surface)/80 backdrop-blur-lg border border-(--color-border) px-4 py-3 rounded-xl shadow-xl shadow-black/5 z-20 reveal reveal-delay-3 hover:-translate-y-1 transition-transform duration-300">
            <div class="text-sm md:text-base font-bold text-(--color-text-primary)">{t(locale, 'hero.badges.2.title')}</div>
            <div class="text-[10px] md:text-xs font-semibold text-(--color-accent-500) uppercase tracking-wider">{t(locale, 'hero.badges.2.subtitle')}</div>
          </div>

          <!-- Floating Stat 3: Frontend -->
          <div class="absolute bottom-[15%] -left-4 sm:-left-8 md:-left-12 bg-(--color-surface)/80 backdrop-blur-lg border border-(--color-border) px-4 py-3 rounded-xl shadow-xl shadow-black/5 z-20 reveal reveal-delay-4 hover:-translate-y-1 transition-transform duration-300">
            <div class="text-sm md:text-base font-bold text-(--color-text-primary)">{t(locale, 'hero.badges.3.title')}</div>
            <div class="text-[10px] md:text-xs font-semibold text-(--color-accent-500) uppercase tracking-wider">{t(locale, 'hero.badges.3.subtitle')}</div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>
