---
/**
 * Footer — Simple footer with links and social
 */
import { t, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-(--color-border) bg-(--color-bg-alt) transition-colors duration-300">
  <div class="container-custom py-12 md:py-16">
    <div class="flex flex-col md:flex-row md:justify-between gap-12 md:gap-8">

      <div class="flex flex-col gap-4 text-left md:max-w-sm">
        <a href={`/${locale}/`} class="flex items-center justify-start group hover:opacity-90 transition-opacity -ml-3 md:-mt-6">
          <img src="/img/logo_portfolio.svg" alt="" class="w-[70px] h-[70px]" aria-hidden="true" />
          <span class="text-xl font-bold tracking-tight text-(--color-text-primary) -ml-3">
            Iván<span class="text-(--color-accent-500)">Roldán</span>
          </span>
        </a>
        <p class="text-sm text-(--color-text-secondary) leading-relaxed max-w-xs">
          {t(locale, 'hero.subtitle').split('.')[0]}. {t(locale, 'about.description').split('.')[1]}.
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div class="flex flex-col gap-4 text-left">
        <h3 class="text-sm font-bold uppercase tracking-wider text-(--color-text-primary)">
          {t(locale, 'nav.home')}
        </h3>
        <nav class="grid grid-cols-2 md:grid-cols-1 gap-x-8 gap-y-2 md:gap-y-3">
          <a href={`/${locale}/#services`} class="text-sm text-(--color-text-secondary) hover:text-(--color-accent-500) transition-colors">
            {t(locale, 'nav.services')}
          </a>
          <a href={`/${locale}/#projects`} class="text-sm text-(--color-text-secondary) hover:text-(--color-accent-500) transition-colors">
            {t(locale, 'nav.projects')}
          </a>
          <a href={`/${locale}/blog/`} class="text-sm text-(--color-text-secondary) hover:text-(--color-accent-500) transition-colors">
            {t(locale, 'nav.blog')}
          </a>
          <a href={`/${locale}/faq/`} class="text-sm text-(--color-text-secondary) hover:text-(--color-accent-500) transition-colors">
            {t(locale, 'nav.faq')}
          </a>
        </nav>
      </div>

      <!-- Column 3: Social & Legal -->
      <div class="flex flex-col gap-6 text-left">
        <div>
          <h3 class="text-sm font-bold uppercase tracking-wider text-(--color-text-primary) mb-4">
            Connect
          </h3>
          <div class="flex items-center justify-start gap-4">
            <!-- Email -->
            <a
              href="mailto:info@rolivstudio.com"
              class="p-2.5 text-(--color-text-secondary) hover:text-white hover:bg-(--color-accent-500) rounded-xl transition-all duration-300 shadow-sm"
              aria-label="Email"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 12.713l-11.985-9.713h23.971l-11.986 9.713zm-5.425-1.822l-6.575-5.329v12.501l6.575-7.172zm10.85 0l6.575 7.172v-12.501l-6.575 5.329zm-1.557 1.261l-3.868 3.135-3.868-3.135-8.11 8.848h23.956l-8.11-8.848z"/>
              </svg>
            </a>
            <!-- WhatsApp -->
            <a
              href="https://wa.me/558183342069"
              class="p-2.5 text-(--color-text-secondary) hover:text-white hover:bg-(--color-accent-500) rounded-xl transition-all duration-300 shadow-sm"
              aria-label="WhatsApp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            </a>
            <!-- GitHub -->
            <a
              href={t(locale, 'social.github')}
              class="p-2.5 text-(--color-text-secondary) hover:text-white hover:bg-(--color-accent-500) rounded-xl transition-all duration-300 shadow-sm"
              aria-label="GitHub"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
            </a>
            <!-- LinkedIn -->
            <a
              href={t(locale, 'social.linkedin')}
              class="p-2.5 text-(--color-text-secondary) hover:text-white hover:bg-(--color-accent-500) rounded-xl transition-all duration-300 shadow-sm"
              aria-label="LinkedIn"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
              </svg>
            </a>
          </div>
        </div>
        
        <div class="flex flex-col gap-2">
          <h3 class="text-sm font-bold uppercase tracking-wider text-(--color-text-primary)">
            Legal
          </h3>
          <nav class="flex flex-col gap-2">
            <a href={`/${locale}/privacy/`} class="text-sm text-(--color-text-secondary) hover:text-(--color-accent-500) transition-colors">
              {t(locale, 'footer.privacy')}
            </a>
            <a href={`/${locale}/terms/`} class="text-sm text-(--color-text-secondary) hover:text-(--color-accent-500) transition-colors">
              {t(locale, 'footer.terms')}
            </a>
          </nav>
        </div>
      </div>

    </div>

    <!-- Copyright bar -->
    <div class="border-t border-(--color-border)/50 mt-10 pt-6">
      <p class="text-xs text-(--color-text-tertiary)">
        {t(locale, 'footer.copyright')}
      </p>
    </div>
  </div>
</footer>
