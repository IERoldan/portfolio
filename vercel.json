{
  "redirects": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-index.xml",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/es/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(sitemap.*\\.xml)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/sitemap.xsl",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/xsl"
        }
      ]
    }
  ]
}
